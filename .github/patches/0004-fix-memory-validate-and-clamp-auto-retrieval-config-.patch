From d1cb3e6adbebdf294d62fad300f2182951259765 Mon Sep 17 00:00:00 2001
From: Claw <claw@atlasclaw-01>
Date: Wed, 4 Feb 2026 02:42:54 +0000
Subject: [PATCH 4/8] fix(memory): validate and clamp auto-retrieval config
 values

- maxTokens: clamped to 100-2000
- maxResults: clamped to 1-10
- minScore: clamped to 0-1

Prevents invalid config from causing misbehavior.
---
 src/memory/auto-retrieval.ts | 17 ++++++++++++++---
 1 file changed, 14 insertions(+), 3 deletions(-)

diff --git a/src/memory/auto-retrieval.ts b/src/memory/auto-retrieval.ts
index 497454545..6dd9ca606 100644
--- a/src/memory/auto-retrieval.ts
+++ b/src/memory/auto-retrieval.ts
@@ -125,11 +125,22 @@ export function resolveAutoRetrievalConfig(
     return null;
   }
 
+  // Validate and clamp config values to safe ranges
+  const maxTokens = Math.max(
+    100,
+    Math.min(2000, autoRetrieval.maxTokens ?? DEFAULT_CONFIG.maxTokens),
+  );
+  const maxResults = Math.max(
+    1,
+    Math.min(10, autoRetrieval.maxResults ?? DEFAULT_CONFIG.maxResults),
+  );
+  const minScore = Math.max(0, Math.min(1, autoRetrieval.minScore ?? DEFAULT_CONFIG.minScore));
+
   return {
     enabled: true, // We know it's enabled if we got here
-    maxTokens: autoRetrieval.maxTokens ?? DEFAULT_CONFIG.maxTokens,
-    maxResults: autoRetrieval.maxResults ?? DEFAULT_CONFIG.maxResults,
-    minScore: autoRetrieval.minScore ?? DEFAULT_CONFIG.minScore,
+    maxTokens,
+    maxResults,
+    minScore,
   };
 }
 
